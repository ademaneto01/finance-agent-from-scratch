# .env.docker - Exemplo de arquivo de ambiente para Docker
# Copie este arquivo para .env antes de rodar o docker-compose

# Qdrant Configuration
QDRANT_API_KEY=qdrant-api-key

# Groq API Key (obtém em https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxx

# OpenAI API Key (opcional)
OPENAI_API_KEY=
